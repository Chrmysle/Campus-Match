/* pages/index/index.wxss — 匹配大厅 */
.page-container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 英雄区（未提交状态） ===== */
.not-submitted-page {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dashboard-page {
  display: flex;
  flex-direction: column;
}

.hero-section {
  text-align: center;
  padding-top: 60rpx;
}

.hero-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 48rpx;
  color: #3D322D;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  line-height: 1.6;
  max-width: 500rpx;
}

.hero-join-btn {
  margin-top: 48rpx;
  padding: 28rpx 80rpx;
  background: linear-gradient(135deg, #C4A484 0%, #B8956E 100%);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(196, 164, 132, 0.35);
  transition: all 0.2s ease;
}

.hero-join-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.hero-join-emoji {
  font-size: 40rpx;
}

.hero-join-text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 4rpx;
}

/* 人格画像预览 */
.personality-preview {
  width: 100%;
  padding: 28rpx;
  box-sizing: border-box;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* ===== 暂停状态（周一 18:00 后未提交） ===== */
.closed-page {
  display: flex;
  flex-direction: column;
}

.closed-banner {
  padding: 32rpx;
  background: rgba(232, 196, 196, 0.25);
  border: 2rpx solid rgba(200, 160, 160, 0.3);
}

.banner-icon {
  font-size: 40rpx;
}

/* ===== 处理中状态（周一 18:00-21:00） ===== */
.processing-page {
  display: flex;
  flex-direction: column;
}

.processing-banner {
  padding: 40rpx 32rpx;
  text-align: center;
}

.processing-emoji {
  font-size: 80rpx;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.processing-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(180, 160, 140, 0.15);
  border-radius: 4rpx;
  overflow: hidden;
  margin-top: 32rpx;
}

.processing-fill {
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, #C4A484, #D4C4B0, #C4A484);
  border-radius: 4rpx;
  animation: pulse-fill 2s ease-in-out infinite;
}

@keyframes pulse-fill {
  0% { transform: translateX(-30%); opacity: 0.6; }
  50% { transform: translateX(70%); opacity: 1; }
  100% { transform: translateX(-30%); opacity: 0.6; }
}

/* ===== 等待状态（已提交本周偏好） ===== */
.waiting-page {
  display: flex;
  flex-direction: column;
}

.completed-page {
  display: flex;
  flex-direction: column;
}

.submitted-banner {
  padding: 32rpx;
  background: rgba(196, 212, 196, 0.3);
  border: 2rpx solid rgba(160, 200, 160, 0.3);
}

.banner-check {
  font-size: 40rpx;
}

.weekly-summary {
  padding: 28rpx;
}

.pref-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 0;
}

/* ===== 头像（通用） ===== */
.match-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8D4C4 0%, #D4C4B0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(80, 60, 40, 0.1);
}

.avatar-emoji {
  font-size: 52rpx;
}

/* ===== 匹配结果卡片（completed 状态） ===== */
.match-list {
  width: 100%;
}

.match-result-card {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
}

.match-score {
  font-size: 32rpx;
  font-weight: 700;
}

.match-summary {
  padding: 12rpx 16rpx;
  background: rgba(247, 244, 239, 0.5);
  border-radius: 12rpx;
  line-height: 1.5;
}

/* ===== 匹配解读 + 破冰锦囊 ===== */
.match-insight-block {
  padding: 24rpx;
  background: rgba(247, 244, 239, 0.6);
  border-radius: 16rpx;
  border: 2rpx solid rgba(180, 160, 140, 0.12);
}

.insight-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.insight-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5D4E44;
}

.insight-text {
  font-size: 26rpx;
  color: #6B5D52;
  line-height: 1.6;
}

.insight-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.insight-ice-item {
  font-size: 26rpx;
  color: #7B6D62;
  line-height: 1.7;
  padding: 4rpx 0;
}

.match-contact {
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(180, 160, 140, 0.12);
}

.contact-label {
  font-size: 26rpx;
  color: #8B7D72;
  font-weight: 500;
}

.contact-value-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  border: 2rpx solid rgba(180, 160, 140, 0.15);
}

.contact-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #3D322D;
  letter-spacing: 2rpx;
}

.contact-copy {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #C4A484 0%, #B8956E 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 30rpx;
}

.contact-copy:active {
  opacity: 0.8;
}

/* ===== 倒计时组件 ===== */
.countdown-box {
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  min-width: 400rpx;
}

/* ===== 开发者工具 ===== */
.dev-tools-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dev-tools-header {
  width: 100%;
  max-width: 500rpx;
  padding: 12rpx 16rpx;
  background: rgba(180, 160, 140, 0.08);
  border-radius: 16rpx;
  text-align: center;
  box-sizing: border-box;
  cursor: pointer;
}

.dev-tools-header:active {
  background: rgba(180, 160, 140, 0.15);
}

.dev-tools-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* 长按触发区 */
.mock-test-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mock-test-divider {
  width: 100%;
  max-width: 500rpx;
  padding: 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.mock-test-hint {
  opacity: 0.6;
}

/* ===== 开发者全局工具栏 ===== */
.dev-global-tools {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
  padding: 16rpx;
  background: rgba(255, 243, 224, 0.3);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(196, 164, 132, 0.2);
}

/* ===== 开发者工具 ===== */
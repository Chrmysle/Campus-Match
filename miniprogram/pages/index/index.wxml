<!-- pages/index/index.wxml — 匹配大厅 -->
<nav-bar title="CampusLink" />

<view class="page-container">

  <!-- 未登录拦截 -->
  <view wx:if="{{!isVerified}}" class="flex-center" style="height:100vh;">
    <text class="text-lg text-soft">请先登录校园账号</text>
  </view>

  <block wx:else>

    <!-- ================================================================== -->
    <!-- 状态 A：未参与本周匹配 → 大按钮引导（提交窗口内，无问卷数据） -->
    <!-- ================================================================== -->
    <view wx:if="{{homepageState === 'not_submitted'}}" class="not-submitted-page">
      <view class="hero-section flex-col flex-center">
        <text class="hero-emoji">🎯</text>
        <text class="hero-title font-title text-xxl">找到你的校园搭子</text>
        <text class="hero-subtitle text-sm text-soft">每周一 21:00 匹配开启 · 直接获取联系方式</text>

        <view class="hero-join-btn" bindtap="onJoinWeeklyMatch">
          <text class="hero-join-emoji">🎯</text>
          <text class="hero-join-text">参与本周匹配</text>
        </view>

        <view class="countdown-box glass-card mt-md">
          <text class="text-xs text-muted">{{countdownLabel || '距提交截止还有'}}</text>
          <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
        </view>
        <text class="text-xs text-muted mt-sm">截止时间：本周一 18:00</text>
      </view>
    </view>

    <!-- ================================================================== -->
    <!-- 状态 A-1：老用户主页（有问卷数据但未提交本周偏好） -->
    <!-- ================================================================== -->
    <view wx:elif="{{homepageState === 'dashboard'}}" class="dashboard-page">
      <view class="flex-col flex-center" style="padding:32rpx 0 24rpx;text-align:center;">
        <text class="hero-emoji">🎯</text>
        <text class="text-xl font-title mt-sm">在这里，找到和你灵魂契合的校园搭子</text>
      </view>

      <view wx:if="{{displayTags.length > 0}}" class="personality-preview glass-card mt-md">
        <view class="flex-row gap-sm" style="align-items:center;">
          <text class="text-md text-bold">🧑 我的画像</text>
        </view>
        <view class="flex-row gap-sm mt-sm">
          <vibe-badge emoji="📍" text="{{userCampus}}" size="sm" />
          <vibe-badge emoji="⏰" text="{{userSchedule}}" size="sm" />
        </view>
        <view class="preview-tags mt-sm">
          <vibe-badge wx:for="{{displayTags}}" wx:key="key" emoji="{{item.emoji}}" text="{{item.label}}" size="sm" />
        </view>
      </view>

      <view class="flex-col flex-center mt-lg">
        <view class="hero-join-btn" bindtap="onJoinWeeklyMatch">
          <text class="hero-join-emoji">🎯</text>
          <text class="hero-join-text">参与本周匹配</text>
        </view>
      </view>
      <view class="countdown-box glass-card mt-md">
        <text class="text-xs text-muted">{{countdownLabel || '距提交截止还有'}}</text>
        <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
      </view>
      <text class="text-xs text-muted mt-sm" style="text-align:center;">截止时间：本周一 18:00</text>
    </view>

    <!-- ================================================================== -->
    <!-- 状态 A-2：本周匹配已暂停（超过周一 18:00 且未提交） -->
    <!-- ================================================================== -->
    <view wx:elif="{{homepageState === 'closed'}}" class="closed-page">
      <view class="closed-banner glass-card">
        <view class="flex-row gap-sm" style="align-items:center;">
          <text class="banner-icon">⏸️</text>
          <text class="text-lg text-bold">本周匹配已暂停</text>
        </view>
        <text class="text-sm text-soft mt-sm">本周的偏好提交已于周一 18:00 截止，请参与下周匹配</text>
      </view>

      <view class="countdown-box glass-card mt-lg">
        <text class="text-xs text-muted">{{countdownLabel || '距下次匹配还有'}}</text>
        <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
      </view>
      <text class="text-xs text-muted mt-sm" style="text-align:center;">下次匹配时间：下周一 21:00</text>

      <view wx:if="{{displayTags.length > 0}}" class="personality-preview glass-card mt-md">
        <text class="text-md text-bold">🧑 我的画像</text>
        <view class="preview-tags mt-sm">
          <vibe-badge wx:for="{{displayTags}}" wx:key="key" emoji="{{item.emoji}}" text="{{item.label}}" size="sm" />
        </view>
      </view>
    </view>

    <!-- ================================================================== -->
    <!-- 状态 A-3：匹配处理中（周一 18:00-21:00 已提交用户） -->
    <!-- ================================================================== -->
    <view wx:elif="{{homepageState === 'processing'}}" class="processing-page">
      <view class="processing-banner glass-card">
        <view class="flex-col flex-center" style="text-align:center;">
          <text class="processing-emoji">⚙️</text>
          <text class="text-xl text-bold mt-sm">正在匹配计算中...</text>
          <text class="text-sm text-soft mt-sm">算法正在根据你的偏好和问卷数据匹配最合适的搭子</text>
        </view>
        <view class="processing-bar mt-lg">
          <view class="processing-fill"></view>
        </view>
      </view>

      <view class="countdown-box glass-card mt-lg">
        <text class="text-xs text-muted">{{countdownLabel || '距放榜还有'}}</text>
        <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
      </view>
      <text class="text-xs text-muted mt-sm" style="text-align:center;">放榜时间：{{nextMatchTime}}</text>

      <view wx:if="{{weeklyPref}}" class="weekly-summary glass-card mt-md">
        <text class="text-md text-bold">📋 本周偏好</text>
        <view class="flex-row gap-sm mt-sm">
          <vibe-badge
            wx:for="{{weeklyVibeTypes}}"
            wx:key="value"
            emoji="{{item.emoji}}"
            text="{{item.label}}"
            size="sm"
          />
        </view>
      </view>
    </view>

    <!-- ================================================================== -->
    <!-- 状态 B：已参与本周匹配 → 等待放榜 -->
    <!-- ================================================================== -->
    <view wx:elif="{{homepageState === 'waiting'}}" class="waiting-page">
      <view class="submitted-banner glass-card">
        <view class="flex-row gap-sm" style="align-items:center;">
          <text class="banner-check">✅</text>
          <text class="text-lg text-bold">已参与本周匹配</text>
        </view>
        <text class="text-sm text-soft mt-sm">等待周一 21:00 放榜结果，届时将揭晓你的推荐搭子及联系方式</text>
      </view>

      <view class="weekly-summary glass-card mt-md">
        <text class="text-md text-bold">📋 本周偏好</text>
        <view class="flex-row gap-sm mt-sm">
          <vibe-badge
            wx:for="{{weeklyVibeTypes}}"
            wx:key="value"
            emoji="{{item.emoji}}"
            text="{{item.label}}"
            size="sm"
          />
        </view>
        <view wx:if="{{weeklyPref && weeklyPref.additionalPrefs}}" class="pref-summary mt-sm">
          <text class="text-xs text-soft">期待倾向：{{weeklyPref.additionalPrefs.expectation || 50}}%</text>
          <text class="text-xs text-soft"> · 频率：{{weeklyPref.additionalPrefs.frequency === 'daily' ? '每天' : weeklyPref.additionalPrefs.frequency === 'weekly2-3' ? '每周2-3次' : weeklyPref.additionalPrefs.frequency === 'weekly1' ? '每周1次' : '随缘'}}</text>
        </view>
        <view class="flex-row gap-sm mt-md">
          <glass-button text="修改偏好" type="ghost" size="sm" bindtap="onJoinWeeklyMatch" />
        </view>
      </view>

      <view wx:if="{{displayTags.length > 0}}" class="personality-preview glass-card mt-md">
        <text class="text-md text-bold">🧑 我的画像</text>
        <view class="preview-tags mt-sm">
          <vibe-badge wx:for="{{displayTags}}" wx:key="key" emoji="{{item.emoji}}" text="{{item.label}}" size="sm" />
        </view>
      </view>

      <view class="countdown-box glass-card mt-lg">
        <text class="text-xs text-muted">{{countdownLabel || '距放榜还有'}}</text>
        <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
      </view>
      <text class="text-xs text-muted mt-sm" style="text-align:center;">放榜时间：{{nextMatchTime}}</text>
    </view>

    <!-- ================================================================== -->
    <!-- 状态 D：本周匹配完成 → 展示匹配结果 & 联系方式 -->
    <!-- ================================================================== -->
    <view wx:elif="{{homepageState === 'completed'}}" class="completed-page">
      <view class="submitted-banner glass-card">
        <view class="flex-row gap-sm" style="align-items:center;">
          <text class="banner-check">🎉</text>
          <text class="text-lg text-bold">本周匹配结果</text>
        </view>
        <text class="text-sm text-soft mt-sm">以下是根据你的偏好推荐的同学，快去联系他们吧</text>
      </view>

      <!-- 匹配结果列表 -->
      <view class="match-list mt-lg">
        <view wx:if="{{candidates.length === 0}}" class="flex-center" style="padding:48rpx;">
          <text class="text-md text-soft">暂无匹配结果</text>
        </view>
        <view
          wx:for="{{candidates}}"
          wx:key="candidateId"
          class="match-result-card glass-card mt-sm"
        >
          <!-- 头部：头像 + 名字 + 分数 -->
          <view class="flex-row gap-md" style="align-items:center;">
            <view class="match-avatar">
              <text class="avatar-emoji">{{item.avatar || defaultAvatar}}</text>
            </view>
            <view class="flex-col" style="flex:1;">
              <text class="text-lg text-bold">{{item.name}}</text>
              <view class="flex-row gap-sm mt-xs">
                <text class="text-xs text-soft">{{item.campus || ''}}</text>
                <text class="text-xs text-soft">{{item.scheduleLabel || ''}}</text>
              </view>
            </view>
            <text class="match-score" style="color:{{vibeTheme.colorDark || '#C4A484'}};">{{item.score}}分</text>
          </view>

          <!-- 标签 -->
          <view wx:if="{{item.highlightTags && item.highlightTags.length > 0}}" class="flex-row gap-sm mt-sm">
            <vibe-badge
              wx:for="{{item.highlightTags}}"
              wx:key="key"
              emoji="{{item.emoji}}"
              text="{{item.label}}"
              size="sm"
            />
          </view>

          <!-- AI 摘要 -->
          <view wx:if="{{item.aiSummary}}" class="match-summary mt-sm">
            <text class="text-xs text-soft">{{item.aiSummary}}</text>
          </view>

          <!-- 匹配解读 + 破冰锦囊（统一块） -->
          <view wx:if="{{item.matchInsight}}" class="match-insight-block mt-md">
            <!-- 为什么匹配 -->
            <view class="insight-section">
              <text class="insight-title">🎯 为什么匹配</text>
              <text class="insight-text">{{item.matchInsight.matchReason}}</text>
            </view>

            <!-- 相似点 -->
            <view wx:if="{{item.matchInsight.similarities}}" class="insight-section mt-sm">
              <text class="insight-title">🤝 你们的相似点</text>
              <text class="insight-text">{{item.matchInsight.similarities.personality}}</text>
              <view wx:if="{{item.matchInsight.similarities.tags.length > 0}}" class="insight-tags mt-xs">
                <vibe-badge wx:for="{{item.matchInsight.similarities.tags}}" wx:key="*this" text="{{item}}" size="sm" />
              </view>
            </view>

            <!-- 破冰锦囊 -->
            <view wx:if="{{item.matchInsight.iceBreakers.length > 0}}" class="insight-section mt-sm">
              <text class="insight-title">💡 破冰锦囊</text>
              <text wx:for="{{item.matchInsight.iceBreakers}}" wx:key="*this" class="insight-ice-item text-sm">• {{item}}</text>
            </view>
          </view>

          <!-- 联系方式 -->
          <view class="match-contact mt-md">
            <text class="contact-label">📱 联系方式</text>
            <view class="contact-value-box">
              <text class="contact-value">{{item.contact || '加载中...'}}</text>
              <text wx:if="{{item.contact}}" class="contact-copy" bindtap="onCopyContact" data-contact="{{item.contact}}">复制</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{displayTags.length > 0}}" class="personality-preview glass-card mt-md">
        <text class="text-md text-bold">🧑 我的画像</text>
        <view class="preview-tags mt-sm">
          <vibe-badge wx:for="{{displayTags}}" wx:key="key" emoji="{{item.emoji}}" text="{{item.label}}" size="sm" />
        </view>
      </view>

      <view class="countdown-box glass-card mt-lg">
        <text class="text-xs text-muted">{{countdownLabel || '距下次匹配还有'}}</text>
        <text class="text-xxl text-bold" style="color:#C4A484;">{{countdownText}}</text>
      </view>
      <text class="text-xs text-muted mt-sm" style="text-align:center;">下次匹配：{{nextMatchTime}}</text>

      <view class="flex-center mt-lg">
        <glass-button text="🎯 参与下周匹配" type="primary" size="md" bindtap="onJoinWeeklyMatch" />
      </view>
    </view>

    <!-- ===== 开发者工具（长按版本号展开） ===== -->
    <view wx:if="{{showDevTools}}" class="dev-global-tools">
      <view class="mock-test-divider">
        <text class="text-xs text-muted">🛠 开发者工具</text>
      </view>
      <view class="flex-col flex-center" style="gap:12rpx;padding:16rpx;">
        <glass-button text="🚀 触发云端匹配引擎" type="ghost" size="sm" bindtap="onTriggerMatchEngine" />
        <text class="text-xs text-soft mock-test-hint">调用 weeklyMatchEngine 云函数</text>
        <view style="height:8rpx;"></view>
        <glass-button text="📢 触发放榜" type="ghost" size="sm" bindtap="onTriggerReveal" />
        <text class="text-xs text-soft mock-test-hint">调用 revealMatch 云函数，放榜展示匹配结果</text>
      </view>
    </view>

    <!-- 版本号（长按展开开发者工具） -->
    <view class="flex-center" style="padding:24rpx 0 8rpx;">
      <text class="text-xs text-muted" bindlongpress="onToggleDevTools" style="opacity:0.4;">Campus Link v1.0.0</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{homepageState === 'loading'}}" class="flex-center" style="height:80vh;">
      <text class="text-lg text-soft">加载中...</text>
    </view>

  </block>
</view>
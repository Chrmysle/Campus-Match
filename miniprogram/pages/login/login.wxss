/* pages/login/login.wxss — 校园邮箱验证登录 */
.login-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 20rpx;
}

.login-title {
  font-family: Georgia, 'Songti SC', STSong, SimSun, serif;
  font-size: 44rpx;
  font-weight: 600;
  color: #3D322D;
  letter-spacing: 6rpx;
  margin-top: 16rpx;
}

.login-form {
  width: 100%;
  max-width: 640rpx;
  padding: 32rpx;
}

/* 登录/注册标签切换 */
.tab-bar {
  border-bottom: 2rpx solid rgba(180, 160, 140, 0.15);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  position: relative;
  cursor: pointer;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: #C4A484;
  border-radius: 4rpx;
}

.form-group {
  width: 100%;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: rgba(247, 244, 239, 0.7);
  border-radius: 16rpx;
  border: 2rpx solid rgba(180, 160, 140, 140, 0.18);
  font-size: 30rpx;
  color: #3D322D;
  box-sizing: border-box;
  height: 88rpx;
}

.form-input-code {
  flex: 1;
  min-width: 0;
}

.code-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 28rpx;
  background: rgba(196, 164, 132, 0.15);
  border-radius: 16rpx;
  white-space: nowrap;
  border: 2rpx solid rgba(180, 160, 140, 0.18);
  height: 88rpx;
  min-width: 180rpx;
  box-sizing: border-box;
}

.code-btn:active {
  background: rgba(196, 164, 132, 0.3);
}

.code-btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 协议复选框 */
.agreement-row {
  display: flex;
  align-items: center;
}

.agreement-row checkbox {
  transform: scale(0.85);
  transform-origin: left center;
}

/* 底部切换链接 */
.form-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}
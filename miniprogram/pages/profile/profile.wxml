<!-- pages/profile/profile.wxml — 个人中心（衬线文艺版） -->
<nav-bar title="CampusLink" />

<view class="profile-page">

  <view wx:if="{{!isVerified}}" class="flex-center" style="height:60vh;">
    <text class="text-lg text-soft">请先登录校园账号</text>
  </view>

  <block wx:else>
    <!-- ===== 封面头像区 ===== -->
    <view class="profile-hero">
      <view class="profile-hero-bg"></view>
      <view class="profile-hero-content">
        <view class="profile-avatar-ring" bindtap="onUploadAvatar">
          <view class="profile-avatar">
            <image wx:if="{{isRealAvatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" />
            <text wx:else class="avatar-emoji">{{userInfo.avatar || '👤'}}</text>
            <view class="avatar-upload-hint">📷</view>
          </view>
        </view>
        <view class="profile-name-row" bindlongpress="onEditProfile">
          <text class="profile-name">{{userInfo.name}}</text>
        </view>
        <text class="profile-email">{{userInfo.email}}</text>
        <view class="profile-badges">
          <vibe-badge emoji="📍" text="{{userInfo.campus}}" size="sm" />
          <vibe-badge wx:if="{{gradeLabel !== '未设置'}}" emoji="🎓" text="{{gradeLabel}}" size="sm" />
          <vibe-badge wx:if="{{collegeLabel !== '未设置'}}" emoji="🏛️" text="{{collegeLabel}}" size="sm" />
        </view>
    </view>
    </view>

    <!-- ===== 编辑浮层（修改个人信息时显示） ===== -->
    <view wx:if="{{editingGrade || editingCollege || editingName || editingContact}}" class="edit-overlay-mask" bindtap="onCancelAllEdit"></view>
    <view wx:if="{{editingGrade || editingCollege || editingName || editingContact}}" class="edit-overlay-panel">

      <view wx:if="{{editingName}}" class="edit-field">
        <text class="edit-field-label">昵称</text>
        <input class="edit-input" type="text" value="{{nameInput}}" placeholder="输入昵称" bindinput="onNameInput" maxlength="20" />
        <view class="edit-actions">
          <glass-button text="取消" type="ghost" size="sm" bindtap="onCancelEditName" />
          <glass-button text="保存" type="primary" size="sm" bindtap="onSaveName" />
        </view>
      </view>

      <view wx:if="{{editingGrade}}" class="edit-field">
        <text class="edit-field-label">年级</text>
        <picker mode="selector" range="{{gradeList}}" range-key="label" bindchange="onGradeChange">
          <view class="edit-picker">
            <text>{{gradeLabel}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
        <view class="edit-actions">
          <glass-button text="取消" type="ghost" size="sm" bindtap="onCancelEditGrade" />
          <glass-button text="保存" type="primary" size="sm" bindtap="onSaveGrade" />
        </view>
      </view>

      <view wx:if="{{editingCollege}}" class="edit-field">
        <text class="edit-field-label">学院</text>
        <picker mode="selector" range="{{collegeList}}" bindchange="onCollegeChange">
          <view class="edit-picker">
            <text>{{collegeLabel}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
        <view class="edit-actions">
          <glass-button text="取消" type="ghost" size="sm" bindtap="onCancelEditCollege" />
          <glass-button text="保存" type="primary" size="sm" bindtap="onSaveCollege" />
        </view>
      </view>

      <view wx:if="{{editingContact}}" class="edit-field">
        <text class="edit-field-label">联系方式</text>
        <input class="edit-input" type="text" value="{{contactInput}}" placeholder="填写你的微信号" bindinput="onContactInput" maxlength="30" />
        <view class="edit-actions">
          <glass-button text="取消" type="ghost" size="sm" bindtap="onCancelEditContact" />
          <glass-button text="保存" type="primary" size="sm" bindtap="onSaveContact" />
        </view>
      </view>

    </view>

    <!-- ===== AI 微名片 ===== -->
    <view wx:if="{{userInfo.aiSummary}}" class="glass-card profile-section">
      <view class="section-header">
        <text class="section-title font-title">🤖 AI 微名片</text>
        <text class="section-subtitle">AI Summary</text>
      </view>
      <view class="ai-summary-bubble">
        <text class="ai-summary-text">{{userInfo.aiSummary}}</text>
      </view>
    </view>

    <!-- ===== 我的标签 ===== -->
    <view class="glass-card profile-section">
      <view class="section-header">
        <text class="section-title font-title">我的标签</text>
        <glass-button
          wx:if="{{!editMode}}"
          text="编辑"
          type="ghost"
          size="sm"
          bindtap="onToggleEdit"
        />
      </view>

      <view wx:if="{{!editMode}}" class="tag-cloud">
        <vibe-badge wx:for="{{displayTags}}" wx:key="key" emoji="{{item.emoji}}" text="{{item.label}}" size="md" />
        <view wx:if="{{displayTags.length === 0}}" class="text-sm text-muted" style="padding:16rpx 0;">完成问卷后自动生成</view>
      </view>

      <!-- 编辑模式 -->
      <view wx:if="{{editMode}}" class="tag-edit">
        <view wx:for="{{editableTags}}" wx:key="key" class="tag-edit-row">
          <vibe-badge emoji="{{item.emoji}}" text="{{item.label}}" size="md" />
          <view class="tag-remove-btn" bindtap="onRemoveTag" data-index="{{index}}">
            <text>✕</text>
          </view>
        </view>
        <view class="tag-edit-actions">
          <glass-button text="+ 添加" type="ghost" size="sm" bindtap="onAddCustomTag" />
          <glass-button text="取消" type="ghost" size="sm" bindtap="onToggleEdit" />
          <glass-button text="保存" type="primary" size="sm" bindtap="onSaveTags" />
        </view>
      </view>
    </view>

    <!-- ===== 联系方式 ===== -->
    <view class="glass-card profile-section">
      <view class="section-header">
        <text class="section-title font-title">📞 联系方式</text>
      </view>
      <view class="pref-display">
        <text class="pref-value">{{userInfo.contact || '未设置'}}</text>
      </view>
    </view>

    <!-- ===== 本周偏好 ===== -->
    <view class="glass-card profile-section">
      <view class="section-header">
        <text class="section-title font-title">📋 本周搭子偏好</text>
      </view>
      <view wx:if="{{hasWeeklyPref}}">
        <view class="pref-badges">
          <vibe-badge wx:for="{{weeklyVibeTypes}}" wx:key="value" emoji="{{item.emoji}}" text="{{item.label}}" size="sm" />
        </view>
        <view wx:if="{{weeklyPref.additionalPrefs}}" class="pref-detail">
          <text>期待 {{weeklyPref.additionalPrefs.expectation || 50}}% ·
          频率：{{weeklyPref.additionalPrefs.frequency === 'daily' ? '每天' : weeklyPref.additionalPrefs.frequency === 'weekly2-3' ? '每周2-3次' : weeklyPref.additionalPrefs.frequency === 'weekly1' ? '每周1次' : '随缘'}}</text>
        </view>
        <view class="pref-actions">
          <glass-button text="修改偏好" type="primary" size="sm" bindtap="onJoinWeeklyMatch" />
          <glass-button text="清除" type="ghost" size="sm" bindtap="onClearWeeklyPref" />
        </view>
      </view>
      <view wx:else>
        <text class="text-sm text-soft">尚未参与本周匹配</text>
        <view class="mt-sm">
          <glass-button text="🎯 参与本周匹配" type="primary" size="sm" bindtap="onJoinWeeklyMatch" />
        </view>
      </view>
    </view>

    <!-- ===== 底部 ===== -->
    <view class="profile-footer">
      <glass-button text="🔄 重新测试" type="ghost" size="md" bindtap="onRetakeQuiz" />
    </view>
    <view class="profile-logout">
      <glass-button text="退出登录" type="ghost" size="md" bindtap="onLogout" />
    </view>
  </block>
</view>
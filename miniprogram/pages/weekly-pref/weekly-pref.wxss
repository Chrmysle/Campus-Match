/* pages/weekly-pref/weekly-pref.wxss */

.page-container {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #F7F4EF 0%, #EDE8E0 100%);
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.step-dots {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #D8D0C8;
  transition: all 0.3s;
}

.step-dot.active {
  background: #C4A484;
  width: 40rpx;
  border-radius: 20rpx;
}

/* 步骤容器 */
.step-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 0;
}

/* 步骤底部按钮 */
.step-footer {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 24rpx;
  margin-top: 48rpx;
  padding-bottom: 64rpx;
}

/* ===== 步骤 1: 搭子类型卡片网格 ===== */

.vibe-type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 8rpx;
}

.vibe-type-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 24rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 24rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
  position: relative;
  cursor: pointer;
}

.vibe-type-card:active {
  transform: scale(0.96);
}

.vibe-type-card.selected {
  background: rgba(255,255,255,1);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.vibe-type-emoji {
  font-size: 64rpx;
}

.vibe-type-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3A3A3A;
}

.check-mark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #C4A484;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 步骤 2: 子类别 ===== */

.sub-tab-bar {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  overflow-x: auto;
  padding: 8rpx 0;
  white-space: nowrap;
}

.sub-tab {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.6);
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
  flex-shrink: 0;
}

.sub-tab.active {
  background: #C4A484;
  color: #fff;
  font-weight: 600;
}

.sub-category-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx;
}

.sub-chip {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.7);
  border: 2rpx solid transparent;
  font-size: 26rpx;
  transition: all 0.2s;
}

.sub-chip:active {
  transform: scale(0.95);
}

.sub-chip.selected {
  background: #F0EBE5;
  border-color: #C4A484;
}

.sub-chip-label {
  color: #3A3A3A;
}

.sub-check {
  color: #C4A484;
  font-weight: bold;
}

/* ===== 步骤 3: 额外偏好 ===== */

.pref-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 32rpx 24rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 20rpx;
}

.pref-question {
  font-size: 28rpx;
  font-weight: 600;
  color: #3A3A3A;
}

.slider-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.slider-label {
  font-size: 22rpx;
  color: #888;
  flex-shrink: 0;
}

.slider-wrapper slider {
  flex: 1;
}

.freq-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.freq-option {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.6);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.freq-option:active {
  transform: scale(0.98);
}

.freq-option.selected {
  background: #F0EBE5;
  border-color: #C4A484;
}

.freq-label {
  font-size: 28rpx;
  color: #3A3A3A;
}

/* ===== 性别偏好 ===== */

.gender-options {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.6);
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.gender-option:active {
  transform: scale(0.96);
}

.gender-option.selected {
  background: #F0EBE5;
  border-color: #C4A484;
}

.gender-emoji {
  font-size: 48rpx;
}

.gender-label {
  font-size: 24rpx;
  color: #3A3A3A;
  font-weight: 500;
}

/* ===== 步骤 4: 确认 ===== */

.review-section {
  padding: 32rpx;
  border-radius: 24rpx;
}

.review-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.review-label {
  font-size: 26rpx;
  color: #888;
  font-weight: 500;
}

.review-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.review-chip {
  padding: 8rpx 16rpx;
  background: rgba(196,164,132,0.15);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #8B7355;
}

.review-value {
  font-size: 28rpx;
  color: #3A3A3A;
}

/* ===== 提交暂停状态（周一 18:00 后） ===== */

.closed-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  text-align: center;
  padding: 48rpx 32rpx;
}

.paused-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.countdown-box {
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  min-width: 400rpx;
  width: 100%;
  box-sizing: border-box;
}

.closed-overlay .countdown-box {
  margin-top: 48rpx;
}
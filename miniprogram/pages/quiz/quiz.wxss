/* pages/quiz/quiz.wxss — 动态问卷 */
.page-container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 进度条 */
.quiz-progress-bar {
  padding: 8rpx 0;
}

.progress-track {
  height: 8rpx;
  background: #E8DCD0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #D4B896, #C4A484);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.stage-dot {
  font-size: 28rpx;
  opacity: 0.35;
  transition: all 0.3s ease;
}

.stage-dot-active {
  opacity: 0.7;
}

.stage-dot-current {
  opacity: 1;
  transform: scale(1.3);
}

/* 阶段标题 */
.quiz-stage-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* 题目卡片 */
.quiz-card {
  padding: 40rpx 32rpx;
}

.quiz-q-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.quiz-q-emoji {
  font-size: 48rpx;
}

.quiz-q-text {
  line-height: 1.5;
}

/* Slider */
.quiz-slider-area {
  padding: 20rpx 0;
}

.slider-value-display {
  text-align: center;
  margin-top: 16rpx;
}

/* 选项 */
.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quiz-option {
  display: flex;
  flex-direction: column;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.65);
  border: 2rpx solid rgba(180, 160, 140, 0.16);
  transition: all 0.2s ease;
}

.quiz-option:active {
  transform: scale(0.97);
}

.quiz-option-selected {
  background: rgba(196, 164, 132, 0.18);
  border-color: #C4A484;
}

.multi-option {
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.option-check {
  font-size: 28rpx;
}

.option-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #3D322D;
}

.option-sub {
  margin-top: 6rpx;
}

/* Textarea */
.quiz-textarea {
  width: 100%;
}

.quiz-input {
  width: 100%;
  min-height: 120rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  border: 2rpx solid rgba(180, 160, 140, 0.2);
  font-size: 28rpx;
  color: #3D322D;
  box-sizing: border-box;
}

/* 导航 */
.quiz-nav {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: flex-end;
}
/* components/nav-bar/nav-bar.wxss */
.nav-bar {
  background: #F7F4EF;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 100;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0 32rpx;
  position: relative;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.nav-ornament {
  font-size: 28rpx;
  color: #C4A484;
  opacity: 0.8;
}

.nav-title {
  font-family: Georgia, 'Songti SC', STSong, SimSun, serif;
  font-size: 38rpx;
  font-weight: 600;
  color: #3D322D;
  letter-spacing: 4rpx;
}

.nav-back {
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.6);
  border: 2rpx solid rgba(180,160,140,0.15);
  z-index: 10;
}

.nav-back:active {
  opacity: 0.6;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #3D322D;
  font-weight: 500;
}

.nav-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(180,160,140,0.15) 20%, rgba(180,160,140,0.15) 80%, transparent 100%);
  margin: 0 32rpx;
}
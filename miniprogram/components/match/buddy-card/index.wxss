/* components/match/buddy-card/index.wxss */
.buddy-card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 32rpx;
  border: 2rpx solid rgba(180, 160, 140, 0.2);
  box-shadow: 0 12rpx 40rpx rgba(80, 60, 40, 0.12);
  position: relative;
}

.buddy-compact {
  padding: 24rpx;
  border-radius: 24rpx;
}

/* AI 气泡 */
.card-ai-bubble {
  background: linear-gradient(135deg, rgba(196, 164, 132, 0.18) 0%, rgba(232, 212, 196, 0.12) 100%);
  border-radius: 24rpx 24rpx 24rpx 6rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(180, 160, 140, 0.16);
  position: relative;
}

.ai-text {
  font-size: 26rpx;
  color: #3D322D;
  line-height: 1.6;
}

.ai-tail {
  position: absolute;
  bottom: -12rpx;
  left: 32rpx;
  width: 0; height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-top: 14rpx solid rgba(196, 164, 132, 0.18);
}

/* 头像 */
.card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8D4C4 0%, #D4C4B0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 52rpx;
}

/* 分数 */
.score-row {
  background: rgba(247, 244, 239, 0.6);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* 标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 匹配解释 */
.match-explain {
  padding: 12rpx 16rpx;
  background: rgba(247, 244, 239, 0.5);
  border-radius: 12rpx;
}

/* 三档按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(180, 160, 140, 0.12);
}

.act-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(180, 160, 140, 0.15);
  transition: all 0.18s ease;
}

.act-btn:active {
  transform: scale(0.94);
  opacity: 0.82;
}

.act-pass { background: rgba(232, 196, 196, 0.25); }
.act-meet { background: rgba(212, 208, 196, 0.35); }
.act-heart { background: rgba(196, 212, 196, 0.35); }

.act-emoji { font-size: 40rpx; }
.act-label { font-size: 22rpx; color: #8B7D72; font-weight: 500; }
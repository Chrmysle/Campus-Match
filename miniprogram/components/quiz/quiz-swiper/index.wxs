// index.wxs — 辅助函数，处理 WXML 中不支持的 JS 表达式
function textLength(str) {
  return (str || '').length;
}

function indexOf(arr, value) {
  if (!arr) return -1;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === value) return i;
  }
  return -1;
}

function checkMark(arr, value) {
  return indexOf(arr, value) > -1 ? '✅' : '☐';
}

function isSelected(arr, value) {
  if (!arr) return '';
  return indexOf(arr, value) > -1 ? 'q-option-sel' : '';
}

module.exports = {
  textLength: textLength,
  indexOf: indexOf,
  checkMark: checkMark,
  isSelected: isSelected
};